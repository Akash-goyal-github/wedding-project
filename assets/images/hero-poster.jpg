<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6B0F1A"/>
      <stop offset="100%" style="stop-color:#3D0008"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#8B6914"/>
      <stop offset="50%" style="stop-color:#F5D78E"/>
      <stop offset="100%" style="stop-color:#8B6914"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <!-- Decorative border -->
  <rect x="20" y="20" width="760" height="560" fill="none" stroke="url(#gold)" stroke-width="2" opacity="0.6"/>
  <rect x="35" y="35" width="730" height="530" fill="none" stroke="url(#gold)" stroke-width="1" opacity="0.3"/>
  <!-- Corner ornaments -->
  <text x="30" y="55" fill="#C9A447" font-size="30" opacity="0.8">✦</text>
  <text x="740" y="55" fill="#C9A447" font-size="30" opacity="0.8">✦</text>
  <text x="30" y="590" fill="#C9A447" font-size="30" opacity="0.8">✦</text>
  <text x="740" y="590" fill="#C9A447" font-size="30" opacity="0.8">✦</text>
  <!-- Centre content -->
  <text x="400" y="260" text-anchor="middle" fill="#C9A447" font-family="serif" font-size="72" opacity="0.4">♥</text>
  <text x="400" y="320" text-anchor="middle" fill="#F5D78E" font-family="Georgia, serif" font-size="22" font-style="italic">Priya &amp; Arjun</text>
  <text x="400" y="356" text-anchor="middle" fill="#C9A447" font-family="Georgia, serif" font-size="14" letter-spacing="4">JAIPUR · 2025</text>
  <!-- Decorative line -->
  <line x1="300" y1="370" x2="500" y2="370" stroke="url(#gold)" stroke-width="1.5"/>
  <text x="400" y="400" text-anchor="middle" fill="#F5D78E" font-family="Georgia, serif" font-size="12" opacity="0.6">[ Add your photo here ]</text>
</svg>
